{
  "expo": {
    "name": "Ayushpathi",
    "slug": "ayushpathi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "ayushpathi",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a6b3a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ayushpathi.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a6b3a"
      },
      "package": "com.ayushpathi.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ]
  }
}
