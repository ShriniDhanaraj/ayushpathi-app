# Copy this to .env.local and fill in your values
# NEVER commit .env.local to git

# Supabase — get from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here   # server-side only, never expose to browser

# Google Maps — get from https://console.cloud.google.com
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# Twilio WhatsApp — get from https://console.twilio.com
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886   # Twilio sandbox number (replace with production)

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# MapMyIndia (Mappls) — Phase 1 India maps
# Get token from: https://apis.mappls.com/console/
NEXT_PUBLIC_MAPPLS_ACCESS_TOKEN=your_mappls_access_token_here
NEXT_PUBLIC_MAPS_PROVIDER=mappls   # change to 'google' for Phase 2 global rollout

# Google Maps — Phase 2+ (global) — leave blank until needed
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
