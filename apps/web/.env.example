# Copy this to .env.local and fill in your values
# NEVER commit .env.local to git

# Supabase — create project in ap-south-1 (Mumbai) for DPDP compliance
# Get from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here   # server-side only — never expose to browser

# Maps — MapMyIndia (Mappls) — India-first, Phase 1
# Get token from: https://apis.mappls.com/console/
NEXT_PUBLIC_MAPPLS_TOKEN=your_mappls_token_here
NEXT_PUBLIC_MAPS_PROVIDER=mappls   # swap to 'google' for Phase 2+ global expansion

# Gupshup — India-native WhatsApp Business API (NOT Twilio)
# Get from: https://www.gupshup.io/developer/dashboard
GUPSHUP_API_KEY=your_gupshup_api_key
GUPSHUP_APP_NAME=your_gupshup_app_name
GUPSHUP_SOURCE_NUMBER=917XXXXXXXXX   # your WhatsApp business number (91 + 10 digits)

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OCR for scanned prescriptions (Google Cloud Vision)
GOOGLE_CLOUD_VISION_API_KEY=your_google_vision_api_key_here
